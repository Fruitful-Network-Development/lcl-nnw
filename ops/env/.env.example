# Global stack settings
HOME_LLM_ROOT=.
GATEWAY_ADDR=127.0.0.1:8787
DEFAULT_PROFILE=chat

# llama.cpp runtime
LLAMA_CPP_SERVER_BIN=llama-server
LLAMA_CPP_HOST=127.0.0.1
LLAMA_CPP_PORT=8080

# data roots
DATA_MODELS_DIR=./data/models  # use lowercase slug subdirectories, e.g. qwen2.5-coder-7b-instruct
DATA_SESSIONS_DIR=./data/sessions
DATA_CACHE_DIR=./data/caches
DATA_VECTOR_DIR=./data/vector_store
